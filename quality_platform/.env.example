# =============================================================================
# Quality Platform — Environment Variables Template
# Copy this file to .env and fill in real values before deploying.
# =============================================================================

# NOTE: NEXT_PUBLIC_API_URL is NOT set here.
# It is a build-time variable passed as a Docker build arg in docker-compose.prod.yml.
# For production behind Nginx, it should be EMPTY (relative paths) so Nginx proxies /api/ correctly.

# ── JWT / Auth ──────────────────────────────────────────────
SECRET_KEY=CHANGE-ME-to-a-long-random-string

# ── Database (SQLite by default — data dir is volume-mounted) ─
# DATABASE_URL=sqlite:///./data/quality_news.db

# ── Admin user (created on first startup) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=System Administrator

# ── Twitter / X API v2 (Saudi family & society accounts) ────
TWITTER_BEARER_TOKEN=

# ── Azure AI (primary Claude provider) ──────────────────────
AZURE_API_URL=https://transformellica-gpt5-1.services.ai.azure.com/anthropic/v1/messages
AZURE_API_KEY=
AZURE_MODEL=opus4.5

# ── AWS Bedrock (fallback AI provider) ──────────────────────
AWS_BEARER_TOKEN_BEDROCK=
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Telegram Bot (only needed if running the standalone bot) ─
TELEGRAM_TOKEN=

# ── Apify (optional — for enhanced web scraping) ────────────
APIFY_API_TOKEN=
